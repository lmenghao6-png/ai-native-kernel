#!/usr/bin/expect -f

set iso "build/aegisos/image/aegisos-beta.iso"
set disk "build/aegisos/aegisos-install-test.qcow2"
set ovmf "/usr/share/ovmf/OVMF.fd"
set log_path "build/aegisos/install-test.log"

proc fail {message} {
    puts stderr $message
    exit 1
}

if {![file exists $iso]} {
    fail "ISO not found: $iso"
}
if {![file exists $ovmf]} {
    fail "OVMF not found: $ovmf"
}

file delete -force $disk
if {[catch {exec qemu-img create -q -f qcow2 $disk 4G} result]} {
    fail "Unable to create test disk: $result"
}

log_file -noappend $log_path
set timeout 1200
spawn qemu-system-x86_64 -machine q35 -m 2G -no-reboot \
    -nographic -serial mon:stdio \
    -drive if=pflash,format=raw,readonly=on,file=$ovmf \
    -drive file=$disk,format=qcow2,if=virtio \
    -cdrom $iso

expect {
    "Install AegisOS to Disk" {
        after 500
        send "\033\[B\r"
    }
    timeout { fail "Timed out waiting for the installer boot menu" }
}
expect {
    "Target disk" { send "vda\r" }
    timeout { fail "Timed out waiting for the target disk prompt" }
}
expect {
    "Type yes:" { send "yes\r" }
    timeout { fail "Timed out waiting for erase confirmation" }
}
expect {
    "Power off now?" { send "y\r" }
    timeout { fail "AegisOS installation did not complete" }
}
expect {
    eof {}
    timeout { fail "Timed out waiting for installer shutdown" }
}

set timeout 240
spawn qemu-system-x86_64 -machine q35 -m 1G -no-reboot \
    -nographic -serial mon:stdio \
    -drive if=pflash,format=raw,readonly=on,file=$ovmf \
    -drive file=$disk,format=qcow2,if=virtio

expect {
    "aegisos login:" { send "root\r" }
    timeout { fail "Installed system did not reach a login prompt" }
}
expect {
    "Password:" { send "aegisos\r" }
    timeout { fail "Installed system did not request a password" }
}
expect {
    -re {root@aegisos:.*# } {}
    timeout { fail "Unable to log in to the installed system" }
}

send "test \"\$(findmnt -n -o SOURCE /)\" = /dev/vda3 && grep -Eq '^UUID=.* / ext4 ' /etc/fstab && grep -Eq '^UUID=.* /boot/efi vfat ' /etc/fstab && echo AEGISOS_STORAGE_OK\r"
expect {
    "AEGISOS_STORAGE_OK" {}
    timeout { fail "Installed storage layout is invalid" }
}
send "test -s /etc/machine-id && test -s /etc/ssh/ssh_host_ed25519_key && echo AEGISOS_IDENTITY_OK\r"
expect {
    "AEGISOS_IDENTITY_OK" {}
    timeout { fail "Installed identity or SSH keys are missing" }
}
send "systemctl is-active --quiet aegisosd guardian ssh && test -z \"\$(systemctl --failed --no-legend --plain)\" && echo AEGISOS_INSTALLED_SERVICES_OK\r"
expect {
    "AEGISOS_INSTALLED_SERVICES_OK" {}
    timeout { fail "Installed services are unhealthy" }
}
send "poweroff\r"
expect {
    eof {}
    timeout { fail "Timed out waiting for installed system shutdown" }
}

puts "AegisOS install and reboot test passed"
