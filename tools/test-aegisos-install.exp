#!/usr/bin/expect -f

set version_file [open "VERSION" r]
set version [string trim [read $version_file]]
close $version_file
set iso "build/aegisos/image/aegisos-$version.iso"
set disk "build/aegisos/aegisos-install-test.qcow2"
set ovmf "/usr/share/ovmf/OVMF.fd"
set log_path "build/aegisos/install-test.log"
set admin_user "aegisadmin"
set admin_password "AegisOS-Test-2026"
set admin_ssh_key "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHycMH0+K6FQoCemw1/ocvIV4ppfapJ1H61UrIykyiBP aegisos-install-test"

proc fail {message} {
    puts stderr $message
    exit 1
}

if {![file exists $iso]} {
    fail "ISO not found: $iso"
}
if {![file exists $ovmf]} {
    fail "OVMF not found: $ovmf"
}

file delete -force $disk
if {[catch {exec qemu-img create -q -f qcow2 $disk 4G} result]} {
    fail "Unable to create test disk: $result"
}

log_file -noappend $log_path
set timeout 1200
spawn qemu-system-x86_64 -machine q35 -m 2G -no-reboot \
    -nographic -serial mon:stdio \
    -drive if=pflash,format=raw,readonly=on,file=$ovmf \
    -drive file=$disk,format=qcow2,if=virtio \
    -cdrom $iso

expect {
    "Install AegisOS to Disk" {
        after 500
        send "\033\[B\r"
    }
    timeout { fail "Timed out waiting for the installer boot menu" }
}
expect {
    "Target disk" { send "vda\r" }
    timeout { fail "Timed out waiting for the target disk prompt" }
}
expect {
    "Type yes:" { send "yes\r" }
    timeout { fail "Timed out waiting for erase confirmation" }
}
expect {
    "Administrator username:" { send "$admin_user\r" }
    timeout { fail "Timed out waiting for administrator username" }
}
expect {
    "Administrator password:" { send "$admin_password\r" }
    timeout { fail "Timed out waiting for administrator password" }
}
expect {
    "Confirm administrator password:" { send "$admin_password\r" }
    timeout { fail "Timed out waiting for password confirmation" }
}
expect {
    "Administrator SSH public key (optional):" { send "$admin_ssh_key\r" }
    timeout { fail "Timed out waiting for SSH public key prompt" }
}
expect {
    "Power off now?" { send "y\r" }
    timeout { fail "AegisOS installation did not complete" }
}
expect {
    eof {}
    timeout { fail "Timed out waiting for installer shutdown" }
}

set timeout 240
spawn qemu-system-x86_64 -machine q35 -m 1G -no-reboot \
    -nographic -serial mon:stdio \
    -drive if=pflash,format=raw,readonly=on,file=$ovmf \
    -drive file=$disk,format=qcow2,if=virtio

expect {
    "aegisos login:" { send "$admin_user\r" }
    timeout { fail "Installed system did not reach a login prompt" }
}
expect {
    "Password:" { send "$admin_password\r" }
    timeout { fail "Installed system did not request a password" }
}
expect {
    -re {aegisadmin@aegisos:.*\$ } {}
    timeout { fail "Unable to log in to the installed system" }
}

send "test \"\$(findmnt -n -o SOURCE /)\" = /dev/vda3 && grep -Eq '^UUID=.* / ext4 ' /etc/fstab && grep -Eq '^UUID=.* /boot/efi vfat ' /etc/fstab && echo AEGISOS_STORAGE_OK\r"
expect {
    "AEGISOS_STORAGE_OK" {}
    timeout { fail "Installed storage layout is invalid" }
}
send "test -s /etc/machine-id && printf '%s\\n' '$admin_password' | sudo -S test -s /etc/ssh/ssh_host_ed25519_key && echo AEGISOS_IDENTITY_OK\r"
expect {
    "AEGISOS_IDENTITY_OK" {}
    timeout { fail "Installed identity or SSH keys are missing" }
}
send "printf '%s\\n' '$admin_password' | sudo -S passwd -S root | grep -q '^root L' && ! getent passwd aegis-live && ! grep -q 'Live login:' /etc/motd && echo AEGISOS_ACCOUNTS_OK\r"
expect {
    "AEGISOS_ACCOUNTS_OK" {}
    timeout { fail "Installed credentials were not hardened" }
}
send "test -s ~/.ssh/authorized_keys && grep -q 'aegisos-install-test' ~/.ssh/authorized_keys && printf '%s\\n' '$admin_password' | sudo -S test -e /var/lib/aegisos/firstboot-complete && echo AEGISOS_SSH_KEY_OK\r"
expect {
    "AEGISOS_SSH_KEY_OK" {}
    timeout { fail "Installed SSH key or first-boot state is missing" }
}
send "systemctl is-active --quiet aegisosd guardian ssh auditd && test -z \"\$(systemctl --failed --no-legend --plain)\" && test -z \"\$(systemctl show -p User --value aegisosd)\" && test -z \"\$(systemctl show -p User --value guardian)\" && echo AEGISOS_INSTALLED_SERVICES_OK\r"
expect {
    "AEGISOS_INSTALLED_SERVICES_OK" {}
    timeout { fail "Installed services are unhealthy" }
}
send "printf '%s\\n' '$admin_password' | sudo -S aegisctl ai-stop >/dev/null && printf '%s\\n' '$admin_password' | sudo -S test -e /etc/aegisos/agent-disabled && ! systemctl is-active --quiet aegisosd && ! systemctl is-active --quiet guardian && echo AEGISOS_AI_STOP_OK\r"
expect {
    "AEGISOS_AI_STOP_OK" {}
    timeout { fail "Root AI emergency stop did not stop the services" }
}
send "printf '%s\\n' '$admin_password' | sudo -S aegisctl ai-start >/dev/null && printf '%s\\n' '$admin_password' | sudo -S sh -c 'test ! -e /etc/aegisos/agent-disabled' && systemctl is-active --quiet aegisosd guardian && echo AEGISOS_AI_START_OK\r"
expect {
    "AEGISOS_AI_START_OK" {}
    timeout { fail "Root AI emergency stop did not recover the services" }
}
send "printf '%s\\n' '$admin_password' | sudo -S ufw status | grep -q '^Status: active' && echo AEGISOS_INSTALLED_FIREWALL_OK\r"
expect {
    "AEGISOS_INSTALLED_FIREWALL_OK" {}
    timeout { fail "Installed firewall is not active" }
}
send "printf '%s\\n' '$admin_password' | sudo -S poweroff\r"
expect {
    eof {}
    timeout { fail "Timed out waiting for installed system shutdown" }
}

puts "AegisOS install and reboot test passed"
